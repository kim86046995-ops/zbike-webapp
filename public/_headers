# Cache-Control for HTML files - no cache
/static/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Cache-Control for JS/CSS - short cache
/static/*.js
  Cache-Control: public, max-age=300

/static/*.css
  Cache-Control: public, max-age=300

# Cache-Control for images - long cache
/static/*.jpg
  Cache-Control: public, max-age=31536000

/static/*.png
  Cache-Control: public, max-age=31536000

/static/*.gif
  Cache-Control: public, max-age=31536000
