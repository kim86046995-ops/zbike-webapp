<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=0.25, user-scalable=yes">
    <title>오토바이 관리</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-100">
    <div class="container mx-auto px-4 py-6">
        <!-- 헤더 -->
        <div class="flex justify-between items-center mb-6">
            <div>
                <a href="/" class="text-blue-600 hover:text-blue-800 hover:bg-blue-50 px-3 py-2 rounded-lg text-sm mb-2 inline-flex items-center transition-colors cursor-pointer">
                    <i class="fas fa-arrow-left mr-1"></i><span>메인으로</span>
                </a>
                <h1 class="text-2xl font-bold text-gray-800">
                    <i class="fas fa-motorcycle mr-2 text-blue-600"></i>
                    오토바이 관리
                </h1>
            </div>
            <button onclick="openModal()" class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition font-bold">
                <i class="fas fa-plus mr-2"></i>오토바이 등록
            </button>
        </div>

        <!-- 상태 필터 -->
        <div class="bg-white rounded-lg shadow p-4 mb-6">
            <div class="flex gap-3">
                <button onclick="filterMotorcycles('all')" 
                        class="filter-btn px-6 py-2 rounded-lg font-semibold transition active" 
                        data-status="all">
                    전체
                </button>
                <button onclick="filterMotorcycles('available')" 
                        class="filter-btn px-6 py-2 rounded-lg font-semibold transition" 
                        data-status="available">
                    <i class="fas fa-check-circle mr-1 text-green-600"></i>사용가능
                </button>
                <button onclick="filterMotorcycles('rented')" 
                        class="filter-btn px-6 py-2 rounded-lg font-semibold transition" 
                        data-status="rented">
                    <i class="fas fa-clock mr-1 text-blue-600"></i>렌트중
                </button>
                <button onclick="filterMotorcycles('maintenance')" 
                        class="filter-btn px-6 py-2 rounded-lg font-semibold transition" 
                        data-status="maintenance">
                    <i class="fas fa-wrench mr-1 text-orange-600"></i>정비중
                </button>
            </div>
        </div>

        <!-- 오토바이 목록 (카드 형식) -->
        <div id="motorcycleList" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            <!-- 로딩 중 -->
            <div class="col-span-full flex justify-center py-12">
                <div class="text-center">
                    <i class="fas fa-spinner fa-spin text-4xl text-blue-600 mb-3"></i>
                    <p class="text-gray-600">로딩 중...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- 등록/수정 모달 -->
    <div id="motorcycleModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 overflow-y-auto">
        <div class="bg-white rounded-lg shadow-xl w-full max-w-2xl m-4 max-h-[90vh] overflow-y-auto">
            <div class="sticky top-0 bg-white border-b px-6 py-4 flex justify-between items-center">
                <h2 class="text-xl font-bold" id="modalTitle">오토바이 등록</h2>
                <button onclick="closeModal()" class="text-gray-500 hover:text-gray-700">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>
            
            <form id="motorcycleForm" class="p-6">
                <input type="hidden" id="motorcycleId">
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-bold mb-2">번호판 *</label>
                        <input type="text" id="plateNumber" required class="w-full px-3 py-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-sm font-bold mb-2">차량이름 *</label>
                        <input type="text" id="vehicleName" required class="w-full px-3 py-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-sm font-bold mb-2">차대번호 *</label>
                        <input type="text" id="chassisNumber" required class="w-full px-3 py-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-sm font-bold mb-2">키로수 *</label>
                        <input type="number" id="mileage" required class="w-full px-3 py-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-sm font-bold mb-2">연식 *</label>
                        <input type="number" id="modelYear" required class="w-full px-3 py-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-sm font-bold mb-2">보험사 *</label>
                        <input type="text" id="insuranceCompany" required class="w-full px-3 py-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-sm font-bold mb-2">보험 시작일 *</label>
                        <input type="date" id="insuranceStartDate" required class="w-full px-3 py-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-sm font-bold mb-2">보험 종료일 *</label>
                        <input type="date" id="insuranceEndDate" required class="w-full px-3 py-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-sm font-bold mb-2">운전범위 *</label>
                        <input type="text" id="drivingRange" required class="w-full px-3 py-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-sm font-bold mb-2">명의자 *</label>
                        <input type="text" id="ownerName" required class="w-full px-3 py-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-sm font-bold mb-2">보험료 (원) *</label>
                        <input type="number" id="insuranceFee" required class="w-full px-3 py-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-sm font-bold mb-2">차량금액 (원) *</label>
                        <input type="number" id="vehiclePrice" required class="w-full px-3 py-2 border rounded-lg">
                    </div>
                    <div>
                        <label class="block text-sm font-bold mb-2">상태 *</label>
                        <select id="status" required class="w-full px-3 py-2 border rounded-lg">
                            <option value="available">사용가능</option>
                            <option value="rented">렌트중</option>
                            <option value="maintenance">정비중</option>
                        </select>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-bold mb-2">사용 현황 메모</label>
                        <textarea id="usageNotes" rows="3" class="w-full px-3 py-2 border rounded-lg"></textarea>
                    </div>
                </div>

                <div class="flex gap-4 mt-6">
                    <button type="submit" class="flex-1 bg-blue-600 text-white py-3 rounded-lg font-bold hover:bg-blue-700">
                        저장
                    </button>
                    <button type="button" onclick="closeModal()" class="flex-1 bg-gray-300 text-gray-700 py-3 rounded-lg font-bold hover:bg-gray-400">
                        취소
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- 계약 이력 모달 -->
    <div id="historyModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
        <div class="bg-white rounded-lg shadow-xl w-full max-w-4xl m-4 max-h-[90vh] overflow-y-auto">
            <div class="sticky top-0 bg-white border-b px-6 py-4 flex justify-between items-center">
                <h2 class="text-xl font-bold">계약 이력</h2>
                <button onclick="closeHistoryModal()" class="text-gray-500 hover:text-gray-700">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>
            <div id="contractHistory" class="p-6"></div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/axios@1.6.0/dist/axios.min.js"></script>
    <script>
        let motorcycles = [];
        let currentFilter = 'all';

        document.addEventListener('DOMContentLoaded', () => {
            loadMotorcycles();
        });

        async function loadMotorcycles() {
            try {
                const response = await axios.get('/api/motorcycles');
                motorcycles = response.data;
                renderMotorcycles();
            } catch (error) {
                console.error('Error loading motorcycles:', error);
                alert('오토바이 목록을 불러오는데 실패했습니다.');
            }
        }

        function filterMotorcycles(status) {
            currentFilter = status;
            
            // 버튼 활성화 상태 변경
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('active', 'bg-blue-600', 'text-white');
                btn.classList.add('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
            });
            
            const activeBtn = document.querySelector(`[data-status="${status}"]`);
            activeBtn.classList.add('active', 'bg-blue-600', 'text-white');
            activeBtn.classList.remove('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
            
            renderMotorcycles();
        }

        function renderMotorcycles() {
            const filtered = currentFilter === 'all' 
                ? motorcycles 
                : motorcycles.filter(m => m.status === currentFilter);

            const listContainer = document.getElementById('motorcycleList');

            if (filtered.length === 0) {
                listContainer.innerHTML = `
                    <div class="col-span-full text-center py-12">
                        <i class="fas fa-inbox text-6xl text-gray-300 mb-4"></i>
                        <p class="text-gray-600">등록된 오토바이가 없습니다.</p>
                    </div>
                `;
                return;
            }

            listContainer.innerHTML = filtered.map(m => {
                // 보험 기간 계산
                const startDate = new Date(m.insurance_start_date);
                const endDate = new Date(m.insurance_end_date);
                const today = new Date();
                const totalDays = Math.ceil((endDate - startDate) / (1000 * 60 * 60 * 24));
                const elapsedDays = Math.ceil((today - startDate) / (1000 * 60 * 60 * 24));
                const remainingDays = Math.ceil((endDate - today) / (1000 * 60 * 60 * 24));
                const progressPercent = Math.min(100, Math.max(0, (elapsedDays / totalDays) * 100));
                
                // 보험 상태 색상
                let progressColor = 'bg-green-500';
                if (remainingDays < 0) progressColor = 'bg-red-500';
                else if (remainingDays <= 30) progressColor = 'bg-yellow-500';
                else if (progressPercent > 75) progressColor = 'bg-orange-500';
                else if (progressPercent > 50) progressColor = 'bg-blue-500';
                
                // 상태 뱃지
                const statusBadge = {
                    available: '<span class="px-3 py-1 bg-green-100 text-green-800 rounded-full text-xs font-bold"><i class="fas fa-check-circle mr-1"></i>사용가능</span>',
                    rented: '<span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-xs font-bold"><i class="fas fa-clock mr-1"></i>렌트중</span>',
                    maintenance: '<span class="px-3 py-1 bg-orange-100 text-orange-800 rounded-full text-xs font-bold"><i class="fas fa-wrench mr-1"></i>정비중</span>',
                    scrapped: '<span class="px-3 py-1 bg-red-100 text-red-800 rounded-full text-xs font-bold"><i class="fas fa-ban mr-1"></i>폐지</span>'
                };
                
                // 계약 상태 표시
                let contractBadge = '';
                if (m.contract_id) {
                    const contractTypeLabel = {
                        'individual': '리스/렌트',
                        'temp_rent': '임시렌트',
                        'loan': '차용증'
                    };
                    const typeText = contractTypeLabel[m.contract_type] || m.contract_type;
                    contractBadge = `<span class="px-2 py-1 bg-purple-100 text-purple-800 rounded-full text-xs font-bold"><i class="fas fa-file-contract mr-1"></i>${typeText} 진행중</span>`;
                } else if (m.status === 'maintenance') {
                    contractBadge = '<span class="px-2 py-1 bg-orange-100 text-orange-800 rounded-full text-xs font-bold"><i class="fas fa-wrench mr-1"></i>수리중</span>';
                } else if (m.status === 'scrapped') {
                    contractBadge = '<span class="px-2 py-1 bg-red-100 text-red-800 rounded-full text-xs font-bold"><i class="fas fa-ban mr-1"></i>폐지</span>';
                } else {
                    contractBadge = '<span class="px-2 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-bold"><i class="fas fa-inbox mr-1"></i>계약자 없음</span>';
                }

                return `
                    <div class="bg-white rounded-lg shadow-md hover:shadow-xl transition-shadow overflow-hidden border border-gray-200">
                        <!-- 상단: 차량 이미지 영역 -->
                        <div class="bg-gradient-to-br from-blue-500 to-blue-600 p-6 text-white">
                            <div class="flex justify-between items-start mb-4">
                                <div class="flex-1">
                                    <div class="flex items-center gap-2 mb-2">
                                        <i class="fas fa-motorcycle text-2xl"></i>
                                        <h3 class="text-xl font-bold">${m.vehicle_name}</h3>
                                    </div>
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <button onclick="showContracts(${m.id}, '${m.plate_number}')" 
                                                class="text-white hover:text-blue-100 font-semibold flex items-center gap-2 text-lg">
                                            <i class="fas fa-id-card"></i>
                                            ${m.plate_number}
                                            <i class="fas fa-chevron-right text-sm"></i>
                                        </button>
                                        ${contractBadge}
                                    </div>
                                </div>
                                ${statusBadge[m.status] || ''}
                            </div>
                            <p class="text-sm opacity-90">연식: ${m.model_year}년 | 키로수: ${m.mileage.toLocaleString()} km</p>
                        </div>

                        <!-- 중단: 주요 정보 -->
                        <div class="p-4 space-y-3">
                            <!-- 보험 정보 -->
                            <div>
                                <div class="flex justify-between text-xs mb-1">
                                    <span class="font-semibold text-gray-700">${m.insurance_company}</span>
                                    <span class="font-bold ${remainingDays < 0 ? 'text-red-600' : remainingDays <= 30 ? 'text-yellow-600' : 'text-gray-600'}">
                                        ${remainingDays < 0 ? '만료됨' : `D-${remainingDays}`}
                                    </span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="${progressColor} h-2 rounded-full transition-all" style="width: ${progressPercent}%"></div>
                                </div>
                                <p class="text-xs text-gray-500 mt-1">${m.insurance_start_date} ~ ${m.insurance_end_date}</p>
                            </div>

                            <!-- 가격 정보 -->
                            <div class="grid grid-cols-2 gap-2 pt-2 border-t">
                                <div>
                                    <p class="text-xs text-gray-500">차량가격</p>
                                    <p class="font-bold text-gray-700">${m.vehicle_price.toLocaleString()}원</p>
                                </div>
                            </div>

                            <!-- 기타 정보 -->
                            <div class="pt-2 border-t space-y-1 text-xs text-gray-600">
                                <p><i class="fas fa-user w-4"></i> ${m.owner_name}</p>
                                <p><i class="fas fa-map-marker-alt w-4"></i> ${m.driving_range}</p>
                                <p><i class="fas fa-hashtag w-4"></i> ${m.chassis_number}</p>
                            </div>
                        </div>

                        <!-- 하단: 액션 버튼 -->
                        <div class="border-t p-3 bg-gray-50 flex gap-2">
                            <button onclick="editMotorcycle(${m.id})" 
                                    class="flex-1 bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition text-sm font-semibold">
                                <i class="fas fa-edit mr-1"></i>수정
                            </button>
                            <button onclick="deleteMotorcycle(${m.id}, '${m.vehicle_name}')" 
                                    class="flex-1 bg-red-600 text-white py-2 rounded-lg hover:bg-red-700 transition text-sm font-semibold">
                                <i class="fas fa-trash mr-1"></i>삭제
                            </button>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function openModal() {
            document.getElementById('motorcycleModal').classList.remove('hidden');
            document.getElementById('modalTitle').textContent = '오토바이 등록';
            document.getElementById('motorcycleForm').reset();
            document.getElementById('motorcycleId').value = '';
        }

        function closeModal() {
            document.getElementById('motorcycleModal').classList.add('hidden');
        }

        async function editMotorcycle(id) {
            const motorcycle = motorcycles.find(m => m.id === id);
            if (!motorcycle) return;

            document.getElementById('motorcycleId').value = motorcycle.id;
            document.getElementById('plateNumber').value = motorcycle.plate_number;
            document.getElementById('vehicleName').value = motorcycle.vehicle_name;
            document.getElementById('chassisNumber').value = motorcycle.chassis_number;
            document.getElementById('mileage').value = motorcycle.mileage;
            document.getElementById('modelYear').value = motorcycle.model_year;
            document.getElementById('insuranceCompany').value = motorcycle.insurance_company;
            document.getElementById('insuranceStartDate').value = motorcycle.insurance_start_date;
            document.getElementById('insuranceEndDate').value = motorcycle.insurance_end_date;
            document.getElementById('drivingRange').value = motorcycle.driving_range;
            document.getElementById('ownerName').value = motorcycle.owner_name;
            document.getElementById('insuranceFee').value = motorcycle.insurance_fee;
            document.getElementById('vehiclePrice').value = motorcycle.vehicle_price;
            document.getElementById('usageNotes').value = motorcycle.usage_notes || '';
            document.getElementById('status').value = motorcycle.status;

            document.getElementById('modalTitle').textContent = '오토바이 수정';
            document.getElementById('motorcycleModal').classList.remove('hidden');
        }

        async function deleteMotorcycle(id, name) {
            if (!confirm(`정말로 "${name}" 오토바이를 삭제하시겠습니까?`)) return;

            try {
                await axios.delete(`/api/motorcycles/${id}`);
                alert('삭제되었습니다.');
                loadMotorcycles();
            } catch (error) {
                console.error('Error deleting motorcycle:', error);
                alert('삭제에 실패했습니다.');
            }
        }

        document.getElementById('motorcycleForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const id = document.getElementById('motorcycleId').value;
            const data = {
                plate_number: document.getElementById('plateNumber').value,
                vehicle_name: document.getElementById('vehicleName').value,
                chassis_number: document.getElementById('chassisNumber').value,
                mileage: parseInt(document.getElementById('mileage').value),
                model_year: parseInt(document.getElementById('modelYear').value),
                insurance_company: document.getElementById('insuranceCompany').value,
                insurance_start_date: document.getElementById('insuranceStartDate').value,
                insurance_end_date: document.getElementById('insuranceEndDate').value,
                driving_range: document.getElementById('drivingRange').value,
                owner_name: document.getElementById('ownerName').value,
                insurance_fee: parseInt(document.getElementById('insuranceFee').value),
                vehicle_price: parseInt(document.getElementById('vehiclePrice').value),
                usage_notes: document.getElementById('usageNotes').value || '',
                status: document.getElementById('status').value
            };

            try {
                if (id) {
                    await axios.put(`/api/motorcycles/${id}`, data);
                    alert('수정되었습니다.');
                } else {
                    await axios.post('/api/motorcycles', data);
                    alert('등록되었습니다.');
                }
                closeModal();
                loadMotorcycles();
            } catch (error) {
                console.error('Error saving motorcycle:', error);
                alert('저장에 실패했습니다.');
            }
        });

        async function showContracts(motorcycleId, plateNumber) {
            try {
                const response = await axios.get(`/api/motorcycles/${motorcycleId}/contracts`);
                const contracts = response.data;

                const historyHtml = `
                    <h3 class="text-lg font-bold mb-4">${plateNumber} - 계약 이력 (총 ${contracts.length}건)</h3>
                    ${contracts.length === 0 ? '<p class="text-gray-600">계약 이력이 없습니다.</p>' : contracts.map(c => {
                        const statusBadge = {
                            active: '<span class="px-2 py-1 bg-green-100 text-green-800 rounded text-xs font-bold">진행중</span>',
                            completed: '<span class="px-2 py-1 bg-gray-100 text-gray-800 rounded text-xs font-bold">완료</span>',
                            cancelled: '<span class="px-2 py-1 bg-red-100 text-red-800 rounded text-xs font-bold">취소</span>'
                        };
                        const typeText = c.contract_type === 'lease' ? '리스' : '렌트';
                        
                        return `
                            <div class="border rounded-lg p-4 mb-3 hover:bg-gray-50">
                                <div class="flex justify-between items-start mb-2">
                                    <div>
                                        <span class="font-bold text-blue-600">${c.contract_number}</span>
                                        <span class="ml-2 text-sm text-gray-600">${typeText}</span>
                                        ${statusBadge[c.status]}
                                    </div>
                                    <span class="text-sm text-gray-500">${c.created_at.split('T')[0]}</span>
                                </div>
                                <div class="grid grid-cols-2 gap-2 text-sm">
                                    <div><span class="text-gray-600">고객:</span> ${c.customer_name}</div>
                                    <div><span class="text-gray-600">연락처:</span> ${c.customer_phone}</div>
                                    <div><span class="text-gray-600">기간:</span> ${c.start_date} ~ ${c.end_date}</div>
                                    <div><span class="text-gray-600">금액:</span> ${c.monthly_fee?.toLocaleString() || 0}원</div>
                                </div>
                            </div>
                        `;
                    }).join('')}
                `;

                document.getElementById('contractHistory').innerHTML = historyHtml;
                document.getElementById('historyModal').classList.remove('hidden');
            } catch (error) {
                console.error('Error loading contracts:', error);
                alert('계약 이력을 불러오는데 실패했습니다.');
            }
        }

        function closeHistoryModal() {
            document.getElementById('historyModal').classList.add('hidden');
        }
        
        // 스타일 초기화
        document.querySelectorAll('.filter-btn').forEach(btn => {
            if (!btn.classList.contains('active')) {
                btn.classList.add('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
            } else {
                btn.classList.add('bg-blue-600', 'text-white');
            }
        });
    </script>
</body>
</html>
